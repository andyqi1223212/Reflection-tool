# === LLM API ===
# This project uses DeepSeek (OpenAI-compatible API) by default.
# Sign up at https://platform.deepseek.com/ to get an API key.
DEEPSEEK_API_KEY=sk-...

# Optional: override default models (see agents_runtime/llm_client.py)
# DEEPSEEK_REASONING_MODEL=deepseek-v4-pro
# DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
# DEEPSEEK_OPENAI_BASE_URL=https://api.deepseek.com
# DEEPSEEK_REASONING_EFFORT=high
# DEEPSEEK_V4_PRO_THINKING=1

# === Per-user data isolation ===
# Your IC user name. Data lives under users/<IC_USER>/.
# Default: 'default'
IC_USER=default
